# Environment variables for Kenyan Stock Analyzer
# Copy this file to .env and fill in your values

# Data sources (comma-separated, tried in order)
# Options: tradingview, nse_pdf, yahoo_finance
DATA_SOURCES=tradingview,nse_pdf,yahoo_finance

# Cache directory
CACHE_DIR=data

# Email notification settings
ENABLE_EMAIL_NOTIFICATIONS=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECIPIENTS=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Report settings
REPORT_FORMAT=html
REPORT_DIRECTORY=reports
TEMPLATE_DIR=templates

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/analyzer.log

# Market hours (EAT)
MARKET_OPEN=09:00
MARKET_CLOSE=15:00

# Technical analysis parameters
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
BBANDS_PERIOD=20
BBANDS_STD=2.0
SMA_SHORT=20
SMA_LONG=50
EMA_SHORT=12
EMA_LONG=26
ATR_PERIOD=14
STOCH_K=14
STOCH_D=3
VOLUME_SMA_PERIOD=20

# Stock watchlist (used with --watchlist-only flag)
STOCK_SYMBOLS=SCOM,EQTY,KCB,EABL,COOP,ABSA,NCBA,SCBK,IMH,KPLC